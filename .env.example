# PostgreSQL Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/external_brain

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_WEBHOOK_SECRET=your_random_secret_string_here

# Bot Mode: "polling" for local development, "webhook" for Railway deployment
BOT_MODE=polling

# Logging (optional - Telegram channel for log events)
LOG_CHANNEL_ID=your_channel_id_here

# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# Cloudflare R2 Storage (optional - for storing original documents)
R2_ACCOUNT_ID=your_r2_account_id_here
R2_ACCESS_KEY_ID=your_r2_access_key_id_here
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key_here
R2_BUCKET_NAME=brain2-docs

# Obsidian Vault Integration (optional - for note-taking)
OBSIDIAN_VAULT_PATH=/Users/itzikhillel/Library/Mobile Documents/iCloud~md~obsidian/Documents/The Brain

# Railway will provide these automatically
PORT=8000
