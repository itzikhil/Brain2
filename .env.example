# PostgreSQL Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/external_brain

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_WEBHOOK_SECRET=your_random_secret_string_here

# Logging (optional - Telegram channel for log events)
LOG_CHANNEL_ID=your_channel_id_here

# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# Railway will provide these automatically
PORT=8000
